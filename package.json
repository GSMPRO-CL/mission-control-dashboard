{
  "name": "dashboard-gsmpro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "cd dashboard && npm run dev",
    "dev:ai": "cd services/product_intelligence && ./venv/bin/uvicorn main:app --reload --port 8000",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:ai\" --kill-others --names \"NEXT,FASTAPI\" -c \"bgBlue.bold,bgGreen.bold\"",
    "dev": "npm run dev:all",
    "build": "cd dashboard && npm install && npm run build",
    "start": "cd dashboard && npm start",
    "sync:shopify": "node scripts/sync-shopify.js",
    "sync:klaviyo": "node scripts/sync-klaviyo.js",
    "sync:crisp": "node scripts/sync-crisp.js",
    "sync:gsc": "node scripts/sync-gsc.js"
  },
  "dependencies": {
    "@google-analytics/admin": "^9.1.0",
    "@google-analytics/data": "^5.2.2",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/language": "^7.2.1",
    "dotenv": "^17.4.2",
    "google-ads-api": "^23.0.0",
    "google-trends-api": "^4.9.2",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
